function validateSheetSchema(){for(const name in SHEETS){const s=spreadsheet().getSheetByName(name);if(!s)return fail('SHEET_SCHEMA_ERROR','Thiếu sheet '+name);const actual=s.getRange(1,1,1,SHEETS[name].length).getValues()[0];if(SHEETS[name].some((x,i)=>String(actual[i])!==x))return fail('SHEET_SCHEMA_ERROR','Header không đúng: '+name)}return ok('SCHEMA_OK','Cấu trúc Google Sheet hợp lệ')}
function validateAuditPayload(payload){if(!payload||payload.schema_version!=='1.1')return fail('UNSUPPORTED_SCHEMA','Chỉ hỗ trợ schema 1.1');if(!payload.audit_id||!payload.profile||!payload.profile.asset_code||!payload.profile.employee_code)return fail('INVALID_PAYLOAD','Thiếu audit_id, mã tài sản hoặc mã nhân viên');if(!/^[A-Z0-9._-]{2,30}$/.test(payload.profile.employee_code))return fail('INVALID_PAYLOAD','Mã nhân viên không hợp lệ');const copy=JSON.parse(JSON.stringify(payload)),given=copy.record_sha256;delete copy.record_sha256;if(!constantTimeEqual(given,sha256Hex(canonicalStringify(copy))))return fail('HASH_MISMATCH','Dữ liệu gửi lên không thể xác minh');return null}

