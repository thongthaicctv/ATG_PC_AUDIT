function setupScriptProperties(){const p=props();if(!p.getProperty('SERVER_PEPPER'))p.setProperty('SERVER_PEPPER',Utilities.getUuid()+Utilities.getUuid());if(!p.getProperty('API_VERSION'))p.setProperty('API_VERSION','1');if(!p.getProperty('CURRENT_CHANGE_SEQ'))p.setProperty('CURRENT_CHANGE_SEQ','0');if(!p.getProperty('MAX_CLOCK_SKEW_SECONDS'))p.setProperty('MAX_CLOCK_SKEW_SECONDS','300');if(!p.getProperty('DEFAULT_PAGE_SIZE'))p.setProperty('DEFAULT_PAGE_SIZE','200');if(!p.getProperty('MAX_PAGE_SIZE'))p.setProperty('MAX_PAGE_SIZE','500')}
function applyDataValidations(){const deviceSheet=sheet('THIET_BI'),statusColumn=headers('THIET_BI').indexOf('status')+1,roleColumn=headers('THIET_BI').indexOf('role')+1,rowCount=Math.max(1,deviceSheet.getMaxRows()-1);const statusRule=SpreadsheetApp.newDataValidation().requireValueInList(['ACTIVE','BLOCKED','REVOKED'],true).setAllowInvalid(false).setHelpText('Chọn trạng thái thiết bị: ACTIVE, BLOCKED hoặc REVOKED.').build(),roleRule=SpreadsheetApp.newDataValidation().requireValueInList(['SUBMIT','AGGREGATE'],true).setAllowInvalid(false).setHelpText('Chọn quyền của thiết bị.').build();deviceSheet.getRange(2,statusColumn,rowCount,1).setDataValidation(statusRule);deviceSheet.getRange(2,roleColumn,rowCount,1).setDataValidation(roleRule);return ok('VALIDATION_APPLIED','Đã tạo danh sách xổ xuống cho role và status')}
function setupProject(){setupScriptProperties();const ss=spreadsheet();for(const name in SHEETS){let s=ss.getSheetByName(name);if(!s)s=ss.insertSheet(name);if(s.getLastRow()===0){s.getRange(1,1,1,SHEETS[name].length).setValues([SHEETS[name]]);s.setFrozenRows(1);s.getRange(1,1,1,SHEETS[name].length).setBackground('#1F4E78').setFontColor('#FFFFFF').setFontWeight('bold');if(SHEETS[name].length>1)s.getRange(1,1,Math.max(1,s.getMaxRows()),SHEETS[name].length).createFilter()} }const schema=validateSheetSchema();if(!schema.success)return schema;applyDataValidations();return schema}
